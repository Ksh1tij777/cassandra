# Keep host-built artifacts out of the Docker build context. The webbuild stage
# runs its own `npm ci` + `vite build`; a host node_modules (esp. from Windows,
# no exec bits) copied over it breaks `npm run build` with "Permission denied".
web/node_modules
web/dist
.venv
venv
__pycache__
**/__pycache__
.git
.pytest_cache
.mypy_cache
.ruff_cache
spike_output
reports
